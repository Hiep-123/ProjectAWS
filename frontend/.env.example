# ─────────────────────────────────────────────────────────────────────────────
# frontend/.env.example
#
# Copy this file to .env and fill in your values.
# The .env file must NEVER be committed to source control.
#
# In production (CloudFront deployment), API URL and Cognito config are
# injected at deploy time via /config.json — these variables are only
# needed for local development.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Gateway ───────────────────────────────────────────────────────────────
# Get from ApiStack output: EcommerceApiUrl
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/prod
VITE_API_URL=http://localhost:5173

# ── Amazon Cognito ────────────────────────────────────────────────────────────
# Get these values from AuthStack outputs:
#   UserPoolId       → UserPoolId
#   UserPoolClientId → UserPoolClientId
#   CognitoRegion    → CognitoRegion
VITE_COGNITO_USER_POOL_ID=<region>_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=ap-southeast-1

# ── Environment ───────────────────────────────────────────────────────────────
# Valid values: development | production
VITE_ENVIRONMENT=development

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "false" to disable mocks and call live API Gateway endpoints.
# Must be "false" for any real end-to-end testing.
VITE_ENABLE_MOCKS=false
