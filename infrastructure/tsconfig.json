{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "es2022"
    ],
    // ── Output ──────────────────────────────────────────────────────────
    // Compiled JS goes to dist/ instead of next to .ts source files.
    // rootDir is set explicitly so TypeScript mirrors the full source tree.
    "outDir": "dist",
    "rootDir": ".",
    // declaration: false — CDK apps are not libraries; no consumers need
    // .d.ts files from bin/ or lib/. Removes ~30 generated files per build.
    "declaration": false,
    // ── Type checking ────────────────────────────────────────────────────
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": false,
    // ── Source maps ──────────────────────────────────────────────────────
    "inlineSourceMap": true,
    "inlineSources": true,
    // ── Misc ────────────────────────────────────────────────────────────
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "exclude": [
    "node_modules",
    "cdk.out",
    "dist"
  ]
}