# ─────────────────────────────────────────────────────────────────────────────
# infrastructure/.env.example
#
# Copy this file to .env and fill in your values before running CDK commands.
# The .env file must NEVER be committed to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS deployment target ─────────────────────────────────────────────────────
# Your 12-digit AWS account ID.
CDK_DEFAULT_ACCOUNT=123456789012

# Primary deployment region for all stacks (except SecurityStack which is us-east-1).
CDK_DEFAULT_REGION=ap-southeast-2

# ── CORS origin ───────────────────────────────────────────────────────────────
# Set to the CloudFront distribution URL AFTER deploying FrontendStack.
# Leave empty for local development (falls back to http://localhost:5173).
# Example: https://d1234abcdef8.cloudfront.net
ALLOWED_ORIGIN=

# ── CI/CD pipeline (CicdStack) ────────────────────────────────────────────────
# GitHub repository coordinates.
# These can also be passed as CDK context flags:
#   --context githubOwner=... --context githubRepo=... --context githubBranch=...
# If both are set, CDK context takes precedence.
GITHUB_OWNER=your-github-username
GITHUB_REPO=ProjectSecondAWS
GITHUB_BRANCH=main
