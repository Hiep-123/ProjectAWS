# ─────────────────────────────────────────────────────────────────────────────
# infrastructure/.env.example
#
# Copy this file to .env and fill in your values before running CDK commands.
# The .env file must NEVER be committed to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS deployment target ─────────────────────────────────────────────────────
# Your 12-digit AWS account ID.
CDK_DEFAULT_ACCOUNT=123456789012

# Primary deployment region for all stacks (except SecurityStack which is always us-east-1).
CDK_DEFAULT_REGION=ap-southeast-1

# ── CORS origin ───────────────────────────────────────────────────────────────
# Set to the CloudFront distribution URL AFTER deploying FrontendStack.
# Leave empty for local development (falls back to http://localhost:5173).
# Example: https://d1234abcdef8.cloudfront.net
ALLOWED_ORIGIN=

# ── Alert email (MonitoringStack) ─────────────────────────────────────────────
# Email address that receives CloudWatch alarm notifications via SNS.
# After deploying MonitoringStack, AWS will send a subscription confirmation
# email to this address. You MUST click the confirmation link before any
# alarm emails will be delivered.
# Example: malphite4266@gmail.com
ALERT_EMAIL=

# ── WAF WebACL ARN (SecurityStack → FrontendStack) ────────────────────────────
# ARN of the WAF v2 WebACL deployed by SecurityStack (us-east-1).
# Obtain AFTER deploying SecurityStack:
#   aws cloudformation describe-stacks --stack-name SecurityStack \
#     --region us-east-1 \
#     --query "Stacks[0].Outputs[?OutputKey=='EcommerceWafWebAclArn'].OutputValue" \
#     --output text
# Leave empty to deploy FrontendStack without WAF attachment (still functional).
WAF_WEB_ACL_ARN=

