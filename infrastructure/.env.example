
# AWS account id
CDK_DEFAULT_ACCOUNT=123456789012

# Region deploy mặc định
CDK_DEFAULT_REGION=ap-southeast-1

# Origin cho CORS
ALLOWED_ORIGIN=

# Email nhận alarm từ SNS
ALERT_EMAIL=

# ARN của WAF WebACL từ SecurityStack
WAF_WEB_ACL_ARN=

# Thông tin demo user cho script seed
COGNITO_USER_POOL_ID=
DEMO_CUSTOMER_EMAIL=customer@example.com
DEMO_CUSTOMER_PASSWORD=

# VNPay sandbox credentials (used by ApiStack to create secret VNPayConfig)
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNP_RETURN_URL is generated automatically as ${ALLOWED_ORIGIN}/payment/vnpay-return